# Copy this file to ".env.local" for local testing with `vercel dev`.
# In production, set these in the Vercel dashboard (Project -> Settings -> Environment Variables).
# NEVER commit real keys. Use the ROTATED Supabase service-role key.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_secret_key_here
